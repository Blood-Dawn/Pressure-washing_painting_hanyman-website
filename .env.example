# ─────────────────────────────────────────────────────────────────────────────
# .env.example
# Copy this file to .env.local and fill in real values.
# .env.local is in .gitignore so it will NEVER be pushed to GitHub.
# This file is safe to commit because it only contains placeholder values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard -> Settings -> API
# SUPABASE_URL: the base URL for your project (used for all requests)
# SUPABASE_ANON_KEY: public key (safe to use in browser, limited permissions)
# SUPABASE_SERVICE_KEY: secret key (full DB access, SERVER ONLY - never expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── NextAuth ──────────────────────────────────────────────────────────────────
# NEXTAUTH_SECRET: random string used to sign session tokens.
# Generate one with: openssl rand -base64 32
# NEXTAUTH_URL: the full URL of your site (change to your Vercel URL in production)
NEXTAUTH_SECRET=generate-a-random-string-here
NEXTAUTH_URL=http://localhost:3000

# ── SendGrid ─────────────────────────────────────────────────────────────────
# Found in: SendGrid dashboard -> Settings -> API Keys
# SENDGRID_FROM_EMAIL: the verified sender email in your SendGrid account
SENDGRID_API_KEY=SG.your-api-key-here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ── App ───────────────────────────────────────────────────────────────────────
# ADMIN_EMAIL: the email address the business owner uses to log in
# NEXT_PUBLIC_SITE_URL: full public URL (used to build tracking links in emails)
ADMIN_EMAIL=owner@yourbusiness.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
